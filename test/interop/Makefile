# Zenzen DDS interop test Makefile.
#
# Prerequisites:
#   - Cyclone DDS checked out and built at CYCLONE_ROOT (default below)
#   - OpenDDS built at OPENDDS_ROOT (default below)
#   - Zenzen DDS Zig executables already built by "zig build" (see ZZDDS_PUB / ZZDDS_SUB)
#
# Usage:
#   make interop-test-cyclone  — Cyclone interop scenarios 1 & 2
#   make interop-test-opendds  — OpenDDS interop scenarios 3 & 4
#   make bundle-artifacts      — tar up logs/ for post-mortem (after a run)
#   make clean                 — remove generated + compiled files
#   make clean-logs            — remove captured log files

# bash for PIPESTATUS (captures exit code of left side of pipe alongside tee).
SHELL := /bin/bash

# Per-run log directory.  Each process writes <LOGDIR>/s<N>_<name>.log.
# On failure the relevant logs are printed to stdout for CI capture.
LOGDIR := logs

# ── Cyclone DDS ───────────────────────────────────────────────────────────────
# Set CYCLONE_ROOT to your Cyclone DDS build tree, via environment or command line:
#   CYCLONE_ROOT=/path/to/cyclonedds/build make interop-test-cyclone

CYCLONE_ROOT  ?=
CYCLONE_BUILD ?= $(CYCLONE_ROOT)/build
IDLC          ?= $(CYCLONE_BUILD)/bin/idlc

CYCLONE_INCS  := \
    -I$(CYCLONE_ROOT)/src/core/ddsc/include \
    -I$(CYCLONE_ROOT)/src/ddsrt/include \
    -I$(CYCLONE_BUILD)/src/ddsrt/include \
    -I$(CYCLONE_BUILD)/src/core/include

CYCLONE_LIBS  := -L$(CYCLONE_BUILD)/lib -lddsc

CC     ?= cc
CFLAGS := -O2 -g $(CYCLONE_INCS)

# ── OpenDDS ───────────────────────────────────────────────────────────────────
# Prefer OPENDDS_ROOT from the environment; fall back to DDS_ROOT, then the
# local default.  Source setenv.sh (generated by the OpenDDS configure script)
# before invoking opendds_idl or tao_idl so that ACE_ROOT, TAO_ROOT, and
# LD_LIBRARY_PATH are set correctly regardless of how OpenDDS was installed.

OPENDDS_ROOT ?= $(DDS_ROOT)
ACE_ROOT     ?= $(OPENDDS_ROOT)/ACE_wrappers
TAO_ROOT     ?= $(ACE_ROOT)/TAO
OPENDDS_IDL  ?= $(OPENDDS_ROOT)/bin/opendds_idl
TAO_IDL      ?= $(ACE_ROOT)/bin/tao_idl

# If setenv.sh exists (configure-script build), source it before IDL tools.
_SETENV_SH   := $(OPENDDS_ROOT)/setenv.sh
OPENDDS_SETENV := $(if $(wildcard $(_SETENV_SH)),. $(_SETENV_SH) &&,)

OPENDDS_INCS := \
    -I$(OPENDDS_ROOT) \
    -I$(ACE_ROOT) \
    -I$(ACE_ROOT)/TAO \
    -I.

OPENDDS_LIBS := \
    -L$(OPENDDS_ROOT)/lib -L$(ACE_ROOT)/lib \
    -lOpenDDS_Rtps_Udp -lOpenDDS_Rtps -lOpenDDS_Dcps \
    -lTAO_BiDirGIOP -lTAO_PI -lTAO_CodecFactory -lTAO_Valuetype \
    -lTAO_PortableServer -lTAO_AnyTypeCode -lTAO -lACE \
    -ldl -lpthread \
    -Wl,--disable-new-dtags,-rpath,$(OPENDDS_ROOT)/lib \
    -Wl,--disable-new-dtags,-rpath,$(ACE_ROOT)/lib

TAO_IDLFLAGS := --idl-version 4 \
    -Wb,pre_include=ace/pre.h -Wb,post_include=ace/post.h \
    -I$(TAO_ROOT) -I$(OPENDDS_ROOT)

CXX      ?= g++
CXXFLAGS := -std=c++17 -O2 -g $(OPENDDS_INCS)

# ── Zenzen DDS interop binaries (built by "zig build") ─────────────────────────

ZZDDS_PUB      := ../../zig-out/bin/zzdds_interop_pub
ZZDDS_SUB      := ../../zig-out/bin/zzdds_interop_sub
ZZDDS_PUB_FRAG := ../../zig-out/bin/zzdds_interop_pub_frag

.PHONY: all all-opendds interop-test-cyclone interop-test-opendds \
        bundle-artifacts clean clean-logs check-tools-cyclone check-tools-opendds \
        check-frag-bins

check-tools-cyclone:
	@test -x "$(IDLC)" || { echo "ERROR: Cyclone idlc not found at $(IDLC)"; exit 1; }

check-tools-opendds:
	@test -x "$(OPENDDS_IDL)" || { echo "ERROR: opendds_idl not found at $(OPENDDS_IDL)"; exit 1; }
	@test -x "$(TAO_IDL)"     || { echo "ERROR: tao_idl not found at $(TAO_IDL)"; exit 1; }

all: check-tools-cyclone cyclone_pub cyclone_sub cyclone_pub_frag

all-opendds: check-tools-opendds opendds_pub opendds_sub opendds_pub_frag

# ── Cyclone IDL code generation ───────────────────────────────────────────────

HelloWorldData.c HelloWorldData.h: HelloWorldData.idl
	$(IDLC) -l c HelloWorldData.idl

# ── OpenDDS IDL code generation ───────────────────────────────────────────────
# Step 1: opendds_idl generates the TypeSupport IDL and TypeSupportImpl.h/cpp.
# Step 2: tao_idl on the main IDL generates the CORBA C/S stubs.
# Step 3: tao_idl on the TypeSupport IDL generates TypeSupportC/S stubs.

HelloWorldDataTypeSupport.idl \
HelloWorldDataTypeSupportImpl.h HelloWorldDataTypeSupportImpl.cpp: HelloWorldData.idl
	$(OPENDDS_SETENV) $(OPENDDS_IDL) --no-default-nested $<

HelloWorldDataC.h HelloWorldDataC.cpp \
HelloWorldDataS.h HelloWorldDataS.cpp: HelloWorldData.idl
	$(OPENDDS_SETENV) $(TAO_IDL) $(TAO_IDLFLAGS) $<

HelloWorldDataTypeSupportC.h HelloWorldDataTypeSupportC.cpp \
HelloWorldDataTypeSupportS.h HelloWorldDataTypeSupportS.cpp: HelloWorldDataTypeSupport.idl
	$(OPENDDS_SETENV) $(TAO_IDL) $(TAO_IDLFLAGS) $<

# ── OpenDDS TypeSupport objects ───────────────────────────────────────────────

HelloWorldDataTypeSupportImpl.o: HelloWorldDataTypeSupportImpl.cpp \
    HelloWorldDataTypeSupportImpl.h HelloWorldDataTypeSupportC.h HelloWorldDataC.h
	$(CXX) $(CXXFLAGS) -c $<

HelloWorldDataTypeSupportC.o: HelloWorldDataTypeSupportC.cpp HelloWorldDataTypeSupportC.h
	$(CXX) $(CXXFLAGS) -c $<

HelloWorldDataTypeSupportS.o: HelloWorldDataTypeSupportS.cpp HelloWorldDataTypeSupportS.h
	$(CXX) $(CXXFLAGS) -c $<

HelloWorldDataC.o: HelloWorldDataC.cpp HelloWorldDataC.h
	$(CXX) $(CXXFLAGS) -c $<

HelloWorldDataS.o: HelloWorldDataS.cpp HelloWorldDataS.h
	$(CXX) $(CXXFLAGS) -c $<

OPENDDS_TS_OBJS := \
    HelloWorldDataC.o \
    HelloWorldDataS.o \
    HelloWorldDataTypeSupportImpl.o \
    HelloWorldDataTypeSupportC.o \
    HelloWorldDataTypeSupportS.o

# ── Cyclone programs ──────────────────────────────────────────────────────────

cyclone_pub: cyclone_pub.c HelloWorldData.c HelloWorldData.h
	$(CC) $(CFLAGS) -o $@ cyclone_pub.c HelloWorldData.c $(CYCLONE_LIBS) -Wl,-rpath,$(CYCLONE_BUILD)/lib

cyclone_sub: cyclone_sub.c HelloWorldData.c HelloWorldData.h
	$(CC) $(CFLAGS) -o $@ cyclone_sub.c HelloWorldData.c $(CYCLONE_LIBS) -Wl,-rpath,$(CYCLONE_BUILD)/lib

cyclone_pub_frag: cyclone_pub_frag.c HelloWorldData.c HelloWorldData.h
	$(CC) $(CFLAGS) -o $@ cyclone_pub_frag.c HelloWorldData.c $(CYCLONE_LIBS) -Wl,-rpath,$(CYCLONE_BUILD)/lib

# ── OpenDDS programs ──────────────────────────────────────────────────────────

opendds_pub: opendds_pub.cpp $(OPENDDS_TS_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(OPENDDS_LIBS)

opendds_sub: opendds_sub.cpp $(OPENDDS_TS_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(OPENDDS_LIBS)

opendds_pub_frag: opendds_pub_frag.cpp $(OPENDDS_TS_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^ $(OPENDDS_LIBS)

# ── Test scenarios ─────────────────────────────────────────────────────────────
# Each scenario:
#   - Saves stdout+stderr from every process to $(LOGDIR)/s<N>_<name>.log
#   - Streams the foreground process live via tee (visible + captured)
#   - On failure: dumps the background log(s) to stdout for CI artifact capture

interop-test-cyclone: all
	@mkdir -p $(LOGDIR)
	@echo ""
	@echo "=== Scenario 1: Zenzen DDS writer → Cyclone reader ==="
	@LOG_PUB=$(LOGDIR)/s1_zzdds_pub.log; \
	 LOG_SUB=$(LOGDIR)/s1_cyclone_sub.log; \
	 $(ZZDDS_PUB) >"$$LOG_PUB" 2>&1 & PUB_PID=$$!; \
	 sleep 1; \
	 ./cyclone_sub 2>&1 | tee "$$LOG_SUB"; SUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$PUB_PID 2>/dev/null; PUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_pub log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 1 FAILED (cyclone_sub=$$SUB_EXIT zzdds_pub=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 1 PASSED"

	@echo ""
	@echo "=== Scenario 2: Cyclone writer → Zenzen DDS reader ==="
	@LOG_SUB=$(LOGDIR)/s2_zzdds_sub.log; \
	 LOG_PUB=$(LOGDIR)/s2_cyclone_pub.log; \
	 $(ZZDDS_SUB) >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 1; \
	 ./cyclone_pub 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- cyclone_pub log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 2 FAILED (zzdds_sub=$$SUB_EXIT cyclone_pub=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 2 PASSED"

	@echo ""
	@echo "=== Scenario 3: Zenzen DDS writer (DATA_FRAG, frag_size=512) → Cyclone reader ==="
	@LOG_PUB=$(LOGDIR)/s3_zzdds_pub_frag.log; \
	 LOG_SUB=$(LOGDIR)/s3_cyclone_sub.log; \
	 $(ZZDDS_PUB_FRAG) >"$$LOG_PUB" 2>&1 & PUB_PID=$$!; \
	 sleep 1; \
	 ./cyclone_sub 2>&1 | tee "$$LOG_SUB"; SUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$PUB_PID 2>/dev/null; PUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_pub_frag log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 3 FAILED (cyclone_sub=$$SUB_EXIT zzdds_pub_frag=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 3 PASSED"

	@echo ""
	@echo "=== Scenario 4: Cyclone writer (DATA_FRAG, default 1344 B) → Zenzen DDS reader ==="
	@LOG_PUB=$(LOGDIR)/s4_cyclone_pub_frag.log; \
	 LOG_SUB=$(LOGDIR)/s4_zzdds_sub.log; \
	 $(ZZDDS_SUB) >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 1; \
	 ./cyclone_pub_frag 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- cyclone_pub_frag log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 4 FAILED (zzdds_sub=$$SUB_EXIT cyclone_pub_frag=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 4 PASSED"

	@echo ""
	@echo "All Cyclone interop tests passed."

interop-test-opendds: all-opendds
	@mkdir -p $(LOGDIR)
	@echo ""
	@echo "=== Scenario 3: Zenzen DDS writer → OpenDDS reader ==="
	@LOG_SUB=$(LOGDIR)/s3_opendds_sub.log; \
	 LOG_PUB=$(LOGDIR)/s3_zzdds_pub.log; \
	 ./opendds_sub -DCPSConfigFile rtps.ini >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 2; \
	 $(ZZDDS_PUB) 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- opendds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- zzdds_pub log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 3 FAILED (opendds_sub=$$SUB_EXIT zzdds_pub=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 3 PASSED"

	@echo ""
	@echo "=== Scenario 4: OpenDDS writer → Zenzen DDS reader ==="
	@LOG_SUB=$(LOGDIR)/s4_zzdds_sub.log; \
	 LOG_PUB=$(LOGDIR)/s4_opendds_pub.log; \
	 $(ZZDDS_SUB) >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 1; \
	 ./opendds_pub -DCPSConfigFile rtps.ini 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- opendds_pub log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 4 FAILED (zzdds_sub=$$SUB_EXIT opendds_pub=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 4 PASSED"

	@echo ""
	@echo "=== Scenario 5: Zenzen DDS writer (DATA_FRAG, frag_size=512) → OpenDDS reader ==="
	@LOG_SUB=$(LOGDIR)/s5_opendds_sub.log; \
	 LOG_PUB=$(LOGDIR)/s5_zzdds_pub_frag.log; \
	 ./opendds_sub -DCPSConfigFile rtps.ini >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 2; \
	 $(ZZDDS_PUB_FRAG) 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- opendds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- zzdds_pub_frag log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 5 FAILED (opendds_sub=$$SUB_EXIT zzdds_pub_frag=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 5 PASSED"

	@echo ""
	@echo "=== Scenario 6: OpenDDS writer (DATA_FRAG, default 1024 B) → Zenzen DDS reader ==="
	@LOG_SUB=$(LOGDIR)/s6_zzdds_sub.log; \
	 LOG_PUB=$(LOGDIR)/s6_opendds_pub_frag.log; \
	 $(ZZDDS_SUB) >"$$LOG_SUB" 2>&1 & SUB_PID=$$!; \
	 sleep 1; \
	 ./opendds_pub_frag -DCPSConfigFile rtps.ini 2>&1 | tee "$$LOG_PUB"; PUB_EXIT=$${PIPESTATUS[0]}; \
	 wait $$SUB_PID; SUB_EXIT=$$?; \
	 if [ $$SUB_EXIT -ne 0 ]; then \
	   echo ""; echo "--- zzdds_sub log ($$LOG_SUB) ---"; cat "$$LOG_SUB"; \
	   echo ""; echo "--- opendds_pub_frag log ($$LOG_PUB) ---"; cat "$$LOG_PUB"; \
	   echo ""; echo "Scenario 6 FAILED (zzdds_sub=$$SUB_EXIT opendds_pub_frag=$$PUB_EXIT)"; \
	   exit 1; \
	 fi; \
	 echo "Scenario 6 PASSED"

	@echo ""
	@echo "All OpenDDS interop tests passed."

# ── Artifact bundling ─────────────────────────────────────────────────────────
# Creates a timestamped tarball of all captured logs for post-mortem analysis.
# Run after an interop-test-* target to package the logs directory.

bundle-artifacts:
	@[ -d $(LOGDIR) ] || { echo "No $(LOGDIR)/ found; run a test first."; exit 1; }
	@BUNDLE=interop-artifacts-$$(date +%Y%m%d-%H%M%S).tar.gz; \
	 tar czf "$$BUNDLE" $(LOGDIR)/; \
	 echo "Artifacts bundled: $$BUNDLE"

clean-logs:
	rm -rf $(LOGDIR)

clean:
	rm -f cyclone_pub cyclone_sub cyclone_pub_frag HelloWorldData.c HelloWorldData.h
	rm -f opendds_pub opendds_sub opendds_pub_frag
	rm -f HelloWorldDataC.h HelloWorldDataC.cpp HelloWorldDataC.inl
	rm -f HelloWorldDataS.h HelloWorldDataS.cpp
	rm -f HelloWorldDataTypeSupport.idl
	rm -f HelloWorldDataTypeSupportC.h HelloWorldDataTypeSupportC.cpp HelloWorldDataTypeSupportC.inl
	rm -f HelloWorldDataTypeSupportS.h HelloWorldDataTypeSupportS.cpp
	rm -f HelloWorldDataTypeSupportImpl.h HelloWorldDataTypeSupportImpl.cpp
	rm -f $(OPENDDS_TS_OBJS)
